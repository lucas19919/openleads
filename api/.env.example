# Copy to .env and fill in real values. Never commit .env.
PORT=8787

# Long random string used to sign session cookies.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Bearer token the scraper uses to POST leads. Generate the same way as above.
SERVICE_TOKEN=change-me-scraper-token

# Where the internal web app is served from (CORS). In dev this is the Vite port.
# In production the API serves the app itself, so leave it as the prod origin.
WEB_ORIGIN=http://localhost:5173

# development | production
NODE_ENV=development

# SQLite database location.
DB_PATH=./data/leads.db

# --- AI core ---------------------------------------------------------------
# OpenLeads talks the OpenAI-compatible Chat Completions protocol, so it runs
# against any serving stack. Defaults target a LOCAL Ollama — self-hosted, open
# weights, zero data egress (the DSGVO-friendly default and the point of the
# "German AI" pilot).
#
# Quick start (open source, on your own machine):
#   1) install Ollama, then:  ollama pull llama3.1:8b
#   2) leave the defaults below as-is.
#
# Strong open, German-capable choices for AI_MODEL:
#   llama3.1:8b · qwen2.5:7b-instruct · mistral-small  (via Ollama)
#   openGPT-X/Teuken-7B-instruct-commercial-v0.4       (EU, via vLLM)
#   utter-project/EuroLLM-9B-Instruct                  (EU, via vLLM)
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=llama3.1:8b
# Only needed for hosted OpenAI-compatible endpoints (Mistral, vLLM w/ key, …).
AI_API_KEY=
# Optional friendly label shown in the UI, e.g. "Teuken-7B · self-hosted (EU)".
AI_LABEL=
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=1024
AI_TIMEOUT_MS=120000
# Embedding model for semantic lead search (local Ollama by default):
#   ollama pull nomic-embed-text
AI_EMBED_MODEL=nomic-embed-text

# --- Outreach e-mail (SMTP) ------------------------------------------------
# Optional. Only an *approved* (freigegeben) draft can ever be sent, and every
# message gets an Impressum + opt-out appended automatically (UWG §7 / Art. 21
# DSGVO). Leave blank to disable sending entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true for port 465 (implicit TLS)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                   # e.g. "Web Studio <hallo@webstudio.de>"
