# Copy to .env and fill in real values. Never commit .env.
PORT=8787

# Long random string used to sign session cookies.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Bearer token the scraper uses to POST leads. Generate the same way as above.
SERVICE_TOKEN=change-me-scraper-token

# Where the internal web app is served from (CORS). In dev this is the Vite port.
# In production the API serves the app itself, so leave it as the prod origin.
WEB_ORIGIN=http://localhost:5173

# development | production
NODE_ENV=development

# SQLite database location.
DB_PATH=./data/leads.db
