# Copy to .env and fill in. Never commit .env.

# Anthropic API key for the Sonnet discovery step (https://console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-...

# The CRM API the scraper posts leads to.
CRM_API_URL=http://127.0.0.1:8787
# Must match SERVICE_TOKEN in crm/api/.env
CRM_SERVICE_TOKEN=change-me-scraper-token

# Minimum outdatedness score required to post a lead (0-100). Default 40.
MIN_SCORE=40

# Optional: comma-separated overrides for what to scan.
# SCRAPER_TRADES=Schreiner,Maler,Dachdecker
# SCRAPER_TOWNS=Dachau,Erding,Freising
